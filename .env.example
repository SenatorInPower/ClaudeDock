# ClaudeDock — optional environment variables.
# Anything set here overrides config.json. Handy for systemd / containers / CI.
# (Copy to .env and source it, or export these in your service definition.)

# Telegram integration (optional) — reports, alerts, Mini-App auth.
CLAUDEDOCK_TELEGRAM_BOT_TOKEN=
CLAUDEDOCK_TELEGRAM_CHAT_ID=

# Web controller (optional). Leave the secret empty to auto-generate one.
CLAUDEDOCK_WEB_URL_SECRET=
CLAUDEDOCK_WEB_HOST=127.0.0.1
CLAUDEDOCK_WEB_PORT=8765

# Path to the `claude` CLI, only if it is not on your PATH.
CLAUDEDOCK_CLAUDE_BIN=
